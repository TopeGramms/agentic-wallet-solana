TELEGRAM_TOKEN=your_telegram_bot_token_here
# Optional alias used by agent files (same value as TELEGRAM_TOKEN)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=https://your-render-service.onrender.com
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
PORT=3000
SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional comma-separated fallback RPC list
SOLANA_RPC_FALLBACKS=https://api.devnet.solana.com,https://rpc.ankr.com/solana_devnet
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_key_here
MISTRAL_API_KEY=your_mistral_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional persistent wallet keys (base58 secret keys, 64-byte decode)
AGENT_ALPHA_PRIVATE_KEY=
AGENT_BETA_PRIVATE_KEY=
AGENT_GAMMA_PRIVATE_KEY=
AUTONOMOUS_WALLET_PRIVATE_KEY=

# Optional autonomous agent tuning
AUTONOMOUS_CHECK_INTERVAL_MINUTES=15
AUTONOMOUS_LOW_BALANCE_SOL=0.8
AUTONOMOUS_HEALTHY_BALANCE_SOL=1.2
AUTONOMOUS_LOG_STATUS_EVERY_CYCLES=4
AUTONOMOUS_AIRDROP_ENABLED=true
AUTONOMOUS_AIRDROP_COOLDOWN_MINUTES=60
AUTONOMOUS_AI_ENABLED=true
AUTONOMOUS_AI_MAX_CALLS_PER_RUN=10
AUTONOMOUS_AI_MIN_INTERVAL_MINUTES=30
AUTONOMOUS_AI_MIN_BALANCE_DELTA_SOL=0.25

# Optional multi-agent tuning
MULTI_AGENT_CHECK_INTERVAL_MINUTES=3
MULTI_AGENT_CYCLES=20
MULTI_AGENT_REPORT_ON_START=true
MULTI_AGENT_AIRDROP_ENABLED=true
MULTI_AGENT_AIRDROP_COOLDOWN_MINUTES=90
MULTI_AGENT_FAUCET_BACKOFF_MINUTES=720
MULTI_AGENT_AI_ENABLED=true
MULTI_AGENT_AI_MAX_CALLS_PER_AGENT=2
MULTI_AGENT_AI_MIN_INTERVAL_MINUTES=60
MULTI_AGENT_AI_MIN_BALANCE_DELTA_SOL=0.2
MULTI_AGENT_AI_THRESHOLD_WINDOW_SOL=0.05

WALLET_PRIVATE_KEY=your_base58_private_key_here_or_leave_blank_to_generate
